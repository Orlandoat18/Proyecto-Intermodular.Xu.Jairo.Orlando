<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>

<?import javafx.scene.media.MediaView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<!--Utilizamos el StackPane porque necesitamos poner elementos uno encima de otro.-->
<StackPane
        xmlns:fx="http://javafx.com/fxml"
        stylesheets="/styles/entrada.css"
        fx:controller="proyecto.code.controller.EntradaController"
>

    <MediaView fx:id="videoFondo" id="videoFondo" fitWidth="800" fitHeight="600" preserveRatio="false"/>

    <VBox alignment="CENTER" spacing="20">

        <VBox alignment="CENTER" spacing="15" styleClass="main">

            <ImageView fx:id="logoCentral" id="logoCentral" fitHeight="120" preserveRatio="true"/>

            <Label text="LA WIKI RETRO DE LOS VIDEOJUEGOS"
                   styleClass="titulo"/>

            <Label text="La enciclopedia colaborativa dedicada a los videojuegos clásicos"
                   textAlignment="CENTER"
                   styleClass="descripcion"/>

            <Label text="Descubre, aprende y comparte la historia del videojuego retro"
                   textAlignment="CENTER"
                   styleClass="descripcion"/>

            <Button text="Inicio" fx:id="btnEntrar" id="btnEntrar" onAction="#irInicio"/>

        </VBox>

        <HBox alignment="CENTER" styleClass="footer">
            <Label text="© 2026 Arcadepedia. Todos los derechos reservados."/>
        </HBox>

    </VBox>

</StackPane>