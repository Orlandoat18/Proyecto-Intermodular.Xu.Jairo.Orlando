<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>

<?import javafx.scene.media.MediaView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<StackPane
        xmlns:fx="http://javafx.com/fxml"
        stylesheets="/styles/entrada.css"
        fx:controller="proyecto.code.controller.EntradaController"
>
    <MediaView fx:id="videoFondo" id="videoFondo" fitWidth="800" fitHeight="600" preserveRatio="false"/>

    <VBox alignment="CENTER" spacing="20">

        <HBox alignment="CENTER" styleClass="header">

            <ImageView fx:id="logoSuperior" id="logoSuperior" fitHeight="80" preserveRatio="true"/>

        </HBox>

        <VBox alignment="CENTER" spacing="15" styleClass="main">

            <ImageView fx:id="logoCentral" id="logoCentral" fitHeight="120" preserveRatio="true"/>

            <Label text="LA WIKI RETRO DE LOS VIDEOJUEGOS"/>

            <Label text="La enciclopedia colaborativa dedicada a los videojuegos clásicos. Descubre, aprende y comparte la historia del videojuego retro."
                   wrapText="true"
                   textAlignment="CENTER"/>

            <Button text="Inicio" fx:id="btnEntrar" id="btnEntrar"/>

        </VBox>

        <HBox alignment="CENTER" styleClass="footer">
            <Label text="© 2026 Arcadepedia. Todos los derechos reservados."/>
        </HBox>

    </VBox>

</StackPane>
